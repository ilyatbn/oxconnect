{
  "manifest_version": 3,
  "name": "oxconnect — OCI tenant switcher",
  "version": "0.1.4",
  "description": "One-click switch between multiple Oracle Cloud (OCI) tenancies / identity domains. Defeats cloud.oracle.com session stickiness.",
  "permissions": ["cookies", "browsingData", "storage", "tabs", "scripting", "offscreen"],
  "host_permissions": [
    "https://cloud.oracle.com/*",
    "https://*.oraclecloud.com/*",
    "https://*.oracle.com/*"
  ],
  "icons": {
    "16": "icons/oxconnect16.png",
    "32": "icons/oxconnect32.png",
    "48": "icons/oxconnect48.png",
    "128": "icons/oxconnect128.png"
  },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "oxconnect — switch OCI tenant",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/oxconnect16.png",
      "32": "icons/oxconnect32.png",
      "48": "icons/oxconnect48.png",
      "128": "icons/oxconnect128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Q", "mac": "MacCtrl+Shift+Q" },
      "description": "Open the oxconnect popup"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.identity.oraclecloud.com/ui/v1/signin*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
